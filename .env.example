# ── Gemini API ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Nano Banana (Image Generation) ──────────────────────
# Path to your base character image (face-consistency source)
BASE_CHARACTER_IMAGE=assets/character.png
# Gemini image generation model (Nano Banana = gemini-2.5-flash-image)
IMAGE_GEN_MODEL=gemini-2.5-flash-image
# LLM model for agents (flash-lite = higher free-tier limits, saves quota)
GEMINI_LLM_MODEL=gemini/gemini-2.5-flash-lite

# ── Instagram ────────────────────────────────────────────
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# ── Output directory ─────────────────────────────────────
OUTPUT_DIR=output
